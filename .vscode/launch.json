            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "stopAtEntry": false,
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug Tests (Linux GCC)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux-gcc/Sem2/Calc/Tests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build linux-gcc-debug",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "stopAtEntry": false,
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
