{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tests (Windows MSVC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows-msvc/Sem2/Calc/Debug/Tests.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build windows-msvc-debug",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Tests (Windows GCC UCRT64)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows-gcc-ucrt64/Sem2/Calc/Tests.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build windows-gcc-ucrt64-debug",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
            "stopAtEntry": false,
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug Tests (Windows Clang UCRT64)",
            "type": "cppdbg",
            "request": "launch",
